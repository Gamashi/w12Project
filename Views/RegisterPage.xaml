<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="w12.Views.RegisterPage"
             xmlns:viewmodel="clr-namespace:w12.ViewModels"
             x:DataType="viewmodel:RegisterPageViewModel"
             BackgroundColor="{StaticResource Primary}"
             Title="RegisterPage">

    <Grid RowDefinitions="2.5*, 7.5*">

        <!-- Cabeçalho Principal -->
        <VerticalStackLayout Grid.Row="0" 
                             VerticalOptions="Center" 
                             HorizontalOptions="Center" 
                             Spacing="5">
            <Label Text="Bem-Vindo!" 
                   TextColor="White" 
                   FontAttributes="Bold" 
                   FontSize="42" 
                   HorizontalTextAlignment="Center"/>
            <Label Text="Crie sua conta para começar" 
                   TextColor="LightGray" 
                   FontSize="16" 
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Container do Formulário (Visual Moderno "Bottom Sheet") -->
        <Border Grid.Row="1" 
                BackgroundColor="Gray"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="40,40,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="15" Opacity="0.15" />
            </Border.Shadow>

            <!-- Formulário Centralizado e com Scroll para evitar quebra em telas menores -->
            <ScrollView VerticalOptions="FillAndExpand">
                <VerticalStackLayout Padding="30,40,30,30" Spacing="24">

                    <!-- Campo: Nome -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nome" 
                               TextColor="{StaticResource Secondary}" 
                               FontAttributes="Bold" 
                               FontSize="14" />
                        <Border BackgroundColor="DimGray" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Entry Text="{Binding User.Name}" 
                                   TextColor="White" 
                                   FontSize="16" 
                                   Placeholder="Digite seu nome completo" 
                                   PlaceholderColor="LightGray"
                                   Margin="15,5" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Campo: E-mail -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="E-mail" 
                               TextColor="{StaticResource Secondary}" 
                               FontAttributes="Bold" 
                               FontSize="14" />
                        <Border BackgroundColor="DimGray" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Entry Text="{Binding User.Email}" 
                                   TextColor="White" 
                                   FontSize="16" 
                                   Keyboard="Email" 
                                   Placeholder="Digite seu e-mail" 
                                   PlaceholderColor="LightGray"
                                   Margin="15,5" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Botão de Ação -->
                    <Button Text="Cadastrar!" 
                            Command="{Binding RegisterCommand}" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            FontSize="18"
                            BackgroundColor="{StaticResource Secondary}" 
                            CornerRadius="12"
                            HeightRequest="55"
                            Margin="0,15,0,0">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Secondary}" Offset="0,4" Radius="10" Opacity="0.4"  />
                        </Button.Shadow>
                    </Button>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>